{
  "name": "burmese-calendar",
  "version": "0.1.4",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "browser": "./cdn/index.js",
  "scripts": {
    "noda": "./build/noda.js",
    "check": "biome check --write src && biome format --write src",
    "build": "./build/index.js",
    "css": "npx @tailwindcss/cli -i ./docs/style.css -o ./docs/index.css --minify"
  },
  "keywords": [
    "Myanmar Calendar",
    "Burmese Calendar"
  ],
  "author": "Pho Thin Maung",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phothinmg/burmese-calendar.git"
  },
  "packageManager": "pnpm@10.3.0",
  "license": "Apache-2.0",
  "description": "Burmese Calendar Calculation",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/cli": "^4.0.6",
    "@types/node": "^22.13.0",
    "dax-sh": "^0.42.0",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@parcel/watcher"
    ]
  },
  "dependencies": {
    "lwe8-build": "^0.1.2"
  }
}
